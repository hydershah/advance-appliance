<script>
    function testimonial_ajax_request() {
        event.preventDefault();

        var _author = $('#_author').val();
        var _company = $('#_company').val();
        var _desc = $('#_desc').val();

        if (!_author || !_company || !_desc) {
            alert('Fill all fields!');
            return;
        }
        $(document).ready(function($) {
            var data = {
                action: 'add_testimonial',
                _author: _author,
                _company: _company,
                _desc: _desc
            };

            // 'ajaxurl' не определена во фронте, поэтому мы добавили её аналог с помощью wp_localize_script()
            jQuery.post( ajaxurl, data, function(response) {
                if (parseInt(response) > 1) {
                    alert('Thank you, you review will be published after validation');
                }
                $('#testimonial_frontend_form').trigger('reset');
            });
        });
    }
</script>
